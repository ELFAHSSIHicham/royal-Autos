{
    "name": "royal-autos/app",
    "description": "Royal Autos — Vente de véhicules d'occasion premium à Montauban",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "phpmailer/phpmailer": "^7.0",
        "stripe/stripe-php": "^20.0"
    },
    "autoload": {
        "psr-4": {
            "Controllers\\": "src/Controllers/",
            "Models\\":      "src/Models/",
            "Views\\":       "src/Views/",
            "Shared\\":      "src/Shared/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    }
}
